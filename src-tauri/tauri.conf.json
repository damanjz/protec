{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Protec",
  "version": "0.2.0",
  "identifier": "dev.protec.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Protec",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "theme": "Dark"
      }
    ],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'" }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
